# dev-platform repo at /home/rich/dev/ — tracks the developer-environment
# source of truth (rules, slash commands, skills, hooks, settings, install
# scripts). Each project under projects/ is its own repo; this gitignore
# uses an aggressive allow-list strategy so projects/ stays untouched.
#
# Strategy: ignore everything by default, then re-include only the files
# that belong to dev-platform itself.

# Ignore-everything default
*

# Re-include top-level files
!.gitignore
!CLAUDE.md
!README.md
!ROADMAP.md
!planning.md

# Re-include top-level directories
!docs/
!tasks/
!scripts/
!commands/
!skills/
!settings/
!hooks/
!extensions/
!scaffolding/
!monitoring/
!shell/
!tests/

# Inside re-included directories, allow only specific extensions to keep
# generated content out of git.
docs/**
tasks/**
scripts/**
commands/**
skills/**
settings/**
hooks/**
extensions/**
scaffolding/**
monitoring/**
shell/**
tests/**

!docs/*.md
!tasks/*.md
!tasks/*.sh
!scripts/*.sh
!commands/*.md
!skills/*.md
!skills/**/*.md
!settings/*.json
!settings/*.md
!hooks/*.sh
!hooks/*.py
!hooks/*.md
!extensions/*.md
!extensions/**/*.md
!extensions/**/*.json
!extensions/**/*.sh
# scaffolding/ holds new-project templates (R4a). Re-include subdirectories
# at any depth (otherwise file-pattern re-includes don't fire — files in
# ignored dirs can't be unignored by file patterns alone), then allow the
# file types the three templates ship: docs (md), config (json/toml/yaml),
# scripts (sh), source (go/py/ts/tsx/mjs/css), build artifacts (Dockerfile*,
# docker-compose*, go.mod, pyproject.toml, .gitignore, .env.example, .gitkeep).
!scaffolding/**/
!scaffolding/*.md
!scaffolding/**/*.md
!scaffolding/**/*.json
!scaffolding/**/*.sh
!scaffolding/**/*.go
!scaffolding/**/*.py
!scaffolding/**/*.ts
!scaffolding/**/*.tsx
!scaffolding/**/*.mjs
!scaffolding/**/*.css
!scaffolding/**/*.toml
!scaffolding/**/*.mod
!scaffolding/**/*.yml
!scaffolding/**/*.yaml
!scaffolding/**/Dockerfile*
!scaffolding/**/.gitignore
!scaffolding/**/.gitkeep
!scaffolding/**/.env.example
!scaffolding/**/.markdownlint.json
!monitoring/**/
!monitoring/*.md
!monitoring/**/*.md
!monitoring/**/*.py
!monitoring/**/*.json
!monitoring/**/*.jsonl
!shell/*.sh
!shell/*.md
# Tests allow-list — fixtures (json/md/txt) + runners (sh) at any depth
!tests/**/
!tests/*.md
!tests/**/*.md
!tests/**/*.sh
!tests/**/*.json
!tests/**/*.txt

# Machine-local overlays (gitignored — keep secrets / per-machine paths out)
settings/*.local.json

# Hard exclude — nested project repos, local Claude config, generated caches
projects/
.claude/
# Override the .claude/ exclude for scaffolding template .claude/ dirs —
# those ship as part of the scaffolding contract for new projects.
!scaffolding/**/.claude/
!scaffolding/**/.claude/*.json
.mypy_cache/
__pycache__/
*.pyc
.DS_Store
